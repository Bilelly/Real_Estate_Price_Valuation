    "import numpy as np\n",
    "import optuna\n",
    "from sklearn.metrics import mean_squared_error, r2_score\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import StandardScaler, OneHotEncoder\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "from sklearn.pipeline import Pipeline\n",
    "\n",
    "# 0. Configuration initiale\n",
    "RANDOM_STATE = 42\n",
    "N_TRIALS = 10 # Augmenté car 2 est trop peu pour une optimisation réelle\n",
    "\n",
    "# Evaluation function - CORRIGÉE : elle doit retourner les valeurs\n",
    "def evaluate_regression(y_true, y_pred):\n",
    "    rmse = np.sqrt(mean_squared_error(y_true, y_pred))\n",
    "    r2 = r2_score(y_true, y_pred)\n",
    "    # On retourne un dictionnaire pour que Optuna puisse l'utiliser\n",
    "    return {\"RMSE\": rmse, \"R2\": r2}\n",
    "\n",
    "# Split features and target variable\n",
    "# (Assure-toi que df est déjà chargé avant cette étape)\n",
    "X = df.drop('prix_m2_vente', axis=1)\n",
    "y = df['prix_m2_vente']\n",
    "\n",
    "# Split the data\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=RANDOM_STATE)\n",
    "\n",
    "# Identify numerical and categorical variables\n",
    "num_var = X_train.select_dtypes(include=np.number).columns.tolist()\n",
    "cat_var = X_train.select_dtypes(include=['object', 'category']).columns.tolist()\n",
    "\n",
    "# Define preprocessing\n",
    "preprocessor = ColumnTransformer(\n",
    "    transformers=[\n",
    "        ('num', StandardScaler(), num_var),           \n",
    "        ('cat', OneHotEncoder(handle_unknown='ignore'), cat_var)\n",
    "    ]\n",
    ")\n",
    "\n",
    "# --- 1. FONCTION OBJECTIVE POUR OPTUNA ---\n",
    "def objective(trial, X, y, preprocessor):\n",
    "    # Espace de recherche\n",
    "    params = {\n",
    "        'n_estimators': trial.suggest_int('n_estimators', 50, 300),\n",
    "        'max_depth': trial.suggest_int('max_depth', 3, 20),\n",
    "        'min_samples_leaf': trial.suggest_int('min_samples_leaf', 1, 10),\n",
    "        'min_samples_split': trial.suggest_int('min_samples_split', 2, 10)\n",
    "    }\n",
    "    \n",
    "    # Création du pipeline\n",
    "    model = RandomForestRegressor(**params, random_state=RANDOM_STATE, n_jobs=-1)\n",
    "    pipeline = Pipeline([('preprocessor', preprocessor), ('regressor', model)])\n",
    "    \n",
    "    # Validation split interne\n",
    "    X_tr, X_val, y_tr, y_val = train_test_split(X, y, test_size=0.2, random_state=RANDOM_STATE)\n",
    "    \n",
    "    pipeline.fit(X_tr, y_tr)\n",
    "    preds = pipeline.predict(X_val)\n",
    "    \n",
    "    # Calcul des métriques\n",
    "    metrics = evaluate_regression(y_val, preds)\n",
    "    \n",
    "    # Retourne le RMSE pour minimisation\n",
    "    return metrics['RMSE']\n",
    "\n",
    "print(f\"Démarrage de l'optimisation Optuna pour {N_TRIALS} essais...\")\n",
    "\n",
    "# --- 2. CRÉATION DU STUDY ---\n",
    "study = optuna.create_study(direction='minimize') \n",
    "study.optimize(lambda trial: objective(trial, X_train, y_train, preprocessor), \n",
    "               n_trials=N_TRIALS)\n",
    "\n",
    "print(\"\\n===== BEST RF RESULTS =====\")\n",
    "print(f\"Best Score (RMSE): {study.best_value:.4f}\")\n",
    "print(\"Best Hyperparameters:\")\n",
    "for k, v in study.best_params.items():\n",
    "    print(f\"  - {k}: {v}\")\n",
    "\n",
    "# --- 3. MODÈLE FINAL ---\n",
    "best_params = study.best_params\n",
    "final_rf_model = RandomForestRegressor(\n",
    "    **best_params,\n",
    "    random_state=RANDOM_STATE,\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "final_pipeline = Pipeline([\n",
    "    ('preprocessor', preprocessor),\n",
    "    ('regressor', final_rf_model)\n",
    "])\n",
    "\n",
    "print(\"\\n=> Training final optimized model on X_train...\")\n",
    "final_pipeline.fit(X_train, y_train)\n",
    "\n",
    "# --- 4. EVALUATION FINALE SUR LE TEST SET ---\n",
    "final_preds = final_pipeline.predict(X_test)\n",
    "final_metrics = evaluate_regression(y_test, final_preds)\n",
    "print(f\"Final Test RMSE: {final_metrics['RMSE']:.4f}\")\n",
    "print(f\"Final Test R2: {final_metrics['R2']:.4f}\")"
   ]
  },
